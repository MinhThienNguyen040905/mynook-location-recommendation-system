1BCgIYIQ!16s%2Fg%2F11ff05hf0b!3m5!1s0x317527005204938f:0x19460fc8d4752b03!8m2!3d10.8468719!4d106.800964!16s%2Fg%2F11w34q6y4j?entry=ttu&g_ep=EgoyMDI2MDUwMi4wIKXMDSoASAFQAw%3D%3D","branch_name":null,"description":"PINK PONG BUFFET là địa điểm được nhập từ Google Maps. Cầu Giấy, Hà Nội","district_id":"91f1d55d-2c08-4d46-a5c2-508698d504a1","address_line":"502 Đ. Lê Văn Việt, Tăng Nhơn Phú, Hồ Chí Minh, Vietnam","category_ids":["bddb1c9e-9a56-4f6c-a1e6-6adb512dc1be","bf3ff727-ecb1-4ee9-900c-c3522f63ba6f","608ee8c3-6509-49a6-9d25-fe22af47ecf5","61c69526-79ef-4374-bd33-5166b60180e3"],"phone_number":"+84 869 066 600","review_count":4085,"opening_hours":null,"menu_image_url":"https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234946/mynook/venues/images/w8mddg1zs9jybledndzs.jpg","source_place_id":"0x3175279d3187379d:0x9896ce5983e4c194","duplicate_reason":"same_source_place_id","matched_venue_id":"3642aac3-59b2-475a-8b47-31d39485553e","selected_reviews":[{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234984/mynook/venues/images/qeduvedaigs6ykewrjcr.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234978/mynook/venues/images/yrj2ctu3gw0ucukuciys.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234970/mynook/venues/images/qxclefaahawotdtwvczq.jpg"],"rating":5,"content":"Nhân viên dễ thương. Đồ ăn ngon, chất lượng ❤️❤️","author_name":"Hà Đặng Thị Ngọc","published_at":"5 months ago","source_review_id":"Ci9DQUlRQUNvZENodHljRjlvT2tkWGVpMU1SMlE1VkZSYUxVNXhRbXRGWjJoTE4wRRAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235000/mynook/venues/images/j0ukecncveh9bhdeu19e.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234989/mynook/venues/images/hlgurolfnahqgbieuxxa.jpg"],"rating":4,"content":"Quầy nướng ướp gia vị phù hợp\\nQuầy thức ăn nóng ko nóng, bánh bao bị nguội nên cứng\\nRau cuốn cải carol, rất khó cuốn. Ăn kèm thì hợp hơn","author_name":"Yến Lê","published_at":"5 months ago","source_review_id":"Ci9DQUlRQUNvZENodHljRjlvT2xKSlQyeDJPR0ZIYldSNmRXVnlNVEpOU21kS1JrRRAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235008/mynook/venues/images/edep0ayzqxbuzvnbyzyk.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235007/mynook/venues/images/pondhjgcsr7xvlhjmumj.jpg"],"rating":5,"content":"Đồ ăn rất ngon, nv rất dễ thương, từng ăn r và quay lại vẫn phục vụ rất chu đáo, sẽ còn tiếp tục ủng hộ","author_name":"Linh Gia","published_at":"4 months ago","source_review_id":"Ci9DQUlRQUNvZENodHljRjlvT2pSWFIybEZSek5NV2tFMGJXVXdNMmRZYTJsdlRWRRAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235013/mynook/venues/images/pvjzf9jzjyabkmrleqkp.jpg"],"rating":5,"content":"Đồ đa số tươi, quầy thả lẩu với rau hơi ít; phô mai viên, bánh bao ngon. Nhân viên chu đáo, niềm nở, chăm sóc khách nhiệt tình.","author_name":"May Birddy","published_at":"3 months ago","source_review_id":"Ci9DQUlRQUNvZENodHljRjlvT2pneVdXMXVlWFI0YXpsWlIyOWtWek5EU2paRE5sRRAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235017/mynook/venues/images/zmznwinuw5gwqykrcyjp.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235017/mynook/venues/images/ch8irivwonc1jhypx8mv.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235018/mynook/venues/images/gqte61sj2pja8qushvtp.jpg"],"rating":5,"content":"Các bạn nhân viên rất là nhiệt tình và ngoan. Mình đi nhiều chỗ rồi. Đồ ăn ở đây rất ok. Nhóm mình sẽ quay lại ủng hộ quán nhiều lần sau nữa. Bạn nhân viên nữ rất là dễ thuong nhé quán. Nên khen thưởng các bạn nhé quán oi. 10* nhé . 5* it quá.","author_name":"Vân Phạm Thị Hồng","published_at":"7 months ago","source_review_id":"Ci9DQUlRQUNvZENodHljRjlvT205aFpWQk5SVUpOYjJOR2MyUnFjVEJJZEc1dE9XYxAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235020/mynook/venues/images/dc1x2mw4hfcycaupnnnz.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235021/mynook/venues/images/h5igpkd1ws9jw5gjj2lg.jpg"],"rating":5,"content":"Đồ ăn ngon, phục vụ tốt, nhân viên thân thiện","author_name":"Anh Đào Thơm Audio","published_at":"7 months ago","source_review_id":"Ci9DQUlRQUNvZENodHljRjlvT25jelEwUTJVbVpYWlRCbVoyTmtZMnhIUWtweWFIYxAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235023/mynook/venues/images/esjcbx6pehqp3ih5fuqf.jpg"],"rating":4,"content":"Đồ ăn ngon, nhân viên thân thiện nên ghé nha","author_name":"Ngô Vũ Thùy Trang","published_at":"3 months ago","source_review_id":"Ci9DQUlRQUNvZENodHljRjlvT2poeVpVVnVUamxaTkhCQlozQXhUVU5XZWpsdU5IYxAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778235027/mynook/venues/images/zd01a47ggkl607zy1w51.jpg"],"rating":5,"content":"đồ ăn 9đ thì phục vụ 10đ\\nchất lượng dịch vụ ở đây tốt\\nnhân viên nhiệt tình dễ thương vô cùng👏🏻","author_name":"Tran Thi Kim Thơm","published_at":"3 months ago","source_review_id":"Ci9DQUlRQUNvZENodHljRjlvT2w5aVUyUmliVWRhVVhCNlNuTlNZVzlrT0VSWFUyYxAB"}],"primary_category_id":"bddb1c9e-9a56-4f6c-a1e6-6adb512dc1be"}'[31m,
