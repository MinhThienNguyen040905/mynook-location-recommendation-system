4m1!1BCgIYIQ!16s%2Fg%2F11ff05hf0b!3m5!1s0x317527636b597cb3:0x11ea0865e71d0da1!8m2!3d10.8413348!4d106.7915206!16s%2Fg%2F11hy2pk7gv?entry=ttu&g_ep=EgoyMDI2MDUwMi4wIKXMDSoASAFQAw%3D%3D","branch_name":null,"description":"Amy’s Coffee là địa điểm được nhập từ Google Maps. Cầu Giấy, Hà Nội","district_id":"91f1d55d-2c08-4d46-a5c2-508698d504a1","address_line":"139 Lã Xuân Oai, Tăng Nhơn Phú, Hồ Chí Minh, Vietnam","category_ids":["bddb1c9e-9a56-4f6c-a1e6-6adb512dc1be"],"phone_number":"+84 867 668 139","review_count":289,"opening_hours":null,"menu_image_url":"https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234473/mynook/venues/images/ory2bmhi0tgxygfnlkas.jpg","source_place_id":"0x3175279d3187379d:0x9896ce5983e4c194","duplicate_reason":"same_source_place_id","matched_venue_id":null,"selected_reviews":[{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234476/mynook/venues/images/zemx1h9c601j2pprtp7p.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234476/mynook/venues/images/ohj38bvukrybevdn4azo.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234477/mynook/venues/images/tfmiryz09sxsud0lnz85.jpg"],"rating":5,"content":"Quán trang trí theo dịp lễ tết, không gian thoáng, nước pha chế ngon, giá rẻ","author_name":"Mây lang thang","published_at":"3 months ago","source_review_id":"Ci9DQUlRQUNvZENodHljRjlvT2tWNFFYWmhkRGgwYlZsRE1YUlRTMnR0YkZkWk9XYxAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234480/mynook/venues/images/pv6m967ay90shbuothu8.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234481/mynook/venues/images/o6fzu13px3qeokh9ytvs.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234482/mynook/venues/images/fpv6khawtwtzqjxb4g2j.jpg"],"rating":5,"content":"Coffee was great, staff was also helpful eventhough they can’t speak english. No food here, they only provide drinks.","author_name":"Christopher Winanto","published_at":"6 months ago","source_review_id":"Ci9DQUlRQUNvZENodHljRjlvT2tkMWFqUktWQzFSVTAxQmNFaGhVRTlLTkdKcU5HYxAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234486/mynook/venues/images/zhibbokddi1bdal0dfbz.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234486/mynook/venues/images/sfa0tf23iqy2i2hornjz.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234485/mynook/venues/images/oz7p3sgvkmo1ja8wdmki.jpg"],"rating":4,"content":"Quán có sân rộng, bàn ghế kê vừa phải, không sít nên ngồi cũng thoải mái.\\nGiá đồ uống hợp lý\\nĐiểm trừ: Bàn ghế xếp lộn xộn, bàn cái đen cái trắng, ghế thì 1 cái bàn mà mấy kiểu ghế nhìn chưa thẩm mỹ.","author_name":"HAI THANH","published_at":"3 years ago","source_review_id":"ChZDSUhNMG9nS0VJQ0FnSUNlMEtYWUp3EAE"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234492/mynook/venues/images/vtuquugxrnxzjfqrtjfb.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234491/mynook/venues/images/c6nzga7hftkl1ilgjny5.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234490/mynook/venues/images/dut7m5phnik2ae3zn9ko.jpg"],"rating":5,"content":"Quán sạch sẽ. Rộng. Nhân viên nhiệt tình.\\nĐồ uống giá cả hợp lý.\\nCó cả không gian trong nhà máy lạnh và ngoài trời dạng sân vườn.","author_name":"Nam Bảo hiểm Hải (Hỗ trợ, tư vấn)","published_at":"3 years ago","source_review_id":"ChZDSUhNMG9nS0VJQ0FnSURPN3IyN0JBEAE"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234495/mynook/venues/images/atoy44qq8dyvmkofhjca.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234494/mynook/venues/images/jwyazcfhnumjnxritta4.jpg"],"rating":5,"content":"Nước ngon nhân viên nhiệt tình - xung quanh bàn ghế sạch sẽ , rất yên tĩnh và mát mẻ để ngồi 🪑 nói chuyện","author_name":"Xuân Quỳnh Lê","published_at":"a year ago","source_review_id":"ChdDSUhNMG9nS0VJQ0FnSUNic3J6TnJBRRAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234499/mynook/venues/images/gudcsg5dswdtu0whbubn.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234498/mynook/venues/images/xep80g0eyhdy7vvsielb.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234498/mynook/venues/images/lkz5hf6qlxbhwnvwbqy4.jpg"],"rating":5,"content":"Amy's Coffee có phong cách bố trí đơn giản, thoáng mát, nhẹ nhàng. Quán có phục vụ cả không gian ngoài trời, trong nhà, phòng lạnh và sân thượng. Thoáng nhìn rất đơn sơ nhưng quán phục vụ rất chuyên nghiệp. Nhân viên nhanh nhẹn và nhiệt tình. Quán có cà phê pha máy tương đối ngon. Tuy nhiên quán không phục vụ lựa chọn cà phê pha phin theo ý thích khách hàng. Ngoài cà phê thì quán còn phục vụ nhiều đồ uống khác, chất lượng tương đối ngon","author_name":"Nguyen Dinh Hung","published_at":"5 years ago","source_review_id":"ChdDSUhNMG9nS0VJQ0FnSUNLdjlhcDN3RRAB"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234503/mynook/venues/images/o70c2pgwhzqqpmpqweyv.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234502/mynook/venues/images/paavqs4pdnhxp5cswtk2.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234503/mynook/venues/images/tejzoaehnd5q6ra75nfp.jpg"],"rating":4,"content":"Đồ uống ở đây đối với mình thấy ngon, giá cả thì không quá mắc so với starbuck, Katinat...Không những vậy không gian thoáng rộng rãi. Gồm trong phòng điểu hoà, sân vườn và roof top.","author_name":"Đạt Nguyễn","published_at":"2 years ago","source_review_id":"ChZDSUhNMG9nS0VJQ0FnSUNwczQ2Q1VBEAE"},{"media":["https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234507/mynook/venues/images/gters8dhfm9qhynyqod6.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234508/mynook/venues/images/isoczeiok21k1gflha1t.jpg","https://res.cloudinary.com/dqksxhlxn/image/upload/v1778234506/mynook/venues/images/qug2a5nsb4rrflcr9sp8.jpg"],"rating":4,"content":"Không gian rộng rãi, thoáng mát. Phòng có điều hòa, có sân vườn và roof top. Đồ ăn thức uống thì tùy. Như loại mình uống trên là Coconut ca cao - uống tạm được.","author_name":"YANG","published_at":"2 years ago","source_review_id":"ChZDSUhNMG9nS0VJQ0FnSUNwczY3UUJnEAE"}],"primary_category_id":"bddb1c9e-9a56-4f6c-a1e6-6adb512dc1be"}`[31m,
