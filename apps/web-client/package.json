{
  "name": "@mynook/web-client",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "serve": {
        "continuous": true,
        "executor": "nx:run-commands",
        "options": {
          "command": "next dev --port 3000",
          "cwd": "apps/web-client"
        }
      }
    }
  },
  "dependencies": {
    "next": "~16.0.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "vaul": "^1.1.2"
  }
}
