# ===========================================
# Supabase PostgreSQL Connection
# ===========================================
# Lấy từ: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Hoặc dùng từng biến riêng lẻ:
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_USERNAME=postgres.[project-ref]
DB_PASSWORD=your-database-password
DB_NAME=postgres

# ===========================================
# App Config
# ===========================================
NODE_ENV=development
