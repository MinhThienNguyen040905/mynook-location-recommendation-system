# ===========================================
# Supabase PostgreSQL Connection
# ===========================================
# Lấy từ: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=
# Hoặc dùng từng biến riêng lẻ:
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

Database_Password=
# ===========================================
# App Config
# ===========================================
NODE_ENV=development

# ===========================================
# Frontend URLs
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ===========================================
# Groq API Key — dùng chung cho cả FE và BE
# FE: Voice Search (Whisper speech-to-text)
# BE: Các model AI phù hợp cho từng chức năng backend
# Lấy từ: https://console.groq.com/keys
# ===========================================
NEXT_PUBLIC_GROQ_API_KEY=
GROQ_API_KEY=

# ===========================================
# Cloudinary — Media Storage (images & videos)
# Lấy từ: https://cloudinary.com/console → Dashboard
# ===========================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================================
# JWT Config
# ===========================================
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=

# ===========================================
# SMTP — Email (OTP xác thực đăng ký)
# Dùng App Password nếu Gmail: https://myaccount.google.com/apppasswords
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MyNook" <noreply@mynook.com>
